FARESCOPE_ENVIRONMENT=development
FARESCOPE_DATABASE_URL=postgresql+asyncpg://farescope:farescope@127.0.0.1:5432/farescope
FARESCOPE_REDIS_URL=redis://127.0.0.1:6379/0
FARESCOPE_CORS_ORIGINS=["http://localhost:5278"]
FARESCOPE_DATABASE_POOL_SIZE=8
FARESCOPE_DATABASE_MAX_OVERFLOW=4
FARESCOPE_DATABASE_POOL_TIMEOUT_SECONDS=2
FARESCOPE_DATABASE_POOL_RECYCLE_SECONDS=1800
FARESCOPE_DATABASE_STATEMENT_TIMEOUT_MS=10000
FARESCOPE_BOOTSTRAP_ADMIN_TOKEN=replace-with-a-long-random-token
FARESCOPE_SECRET_ENCRYPTION_KEY=replace-with-a-fernet-key
FARESCOPE_PUBLIC_REGISTRATION_ENABLED=true
FARESCOPE_NOTIFICATION_DELIVERY_BATCH_SIZE=50
FARESCOPE_NOTIFICATION_DELIVERY_MAX_ATTEMPTS=5
FARESCOPE_NOTIFICATION_RETRY_BASE_SECONDS=60
FARESCOPE_NOTIFICATION_DELIVERY_TIMEOUT_SECONDS=10
FARESCOPE_NOTIFICATION_DELIVERY_STALE_SECONDS=900
FARESCOPE_SESSION_COOKIE_SECURE=false
# Optional local collector network route; do not embed credentials.
# FARESCOPE_COLLECTOR_PROXY_SERVER=http://127.0.0.1:7890
# Standard Google Chrome is the verified default. Set this to chromium only after
# installing the Playwright Chromium binary and validating the provider response.
FARESCOPE_COLLECTOR_BROWSER_CHANNEL=chrome
FARESCOPE_COLLECTOR_BROWSER_HEADLESS=false
FARESCOPE_COLLECTOR_BROWSER_BACKGROUND=true
FARESCOPE_COLLECTION_DISPATCH_LEASE_SECONDS=120
FARESCOPE_COLLECTION_RUN_LEASE_SECONDS=900
FARESCOPE_COLLECTION_RETRY_BASE_SECONDS=300
FARESCOPE_COLLECTION_RETRY_MAX_SECONDS=3600
FARESCOPE_COLLECTION_RETRY_JITTER_RATIO=0.2
FARESCOPE_COLLECTION_COORDINATION_BACKEND=local
FARESCOPE_COLLECTION_COORDINATION_LEASE_TTL_SECONDS=180
FARESCOPE_COLLECTION_COORDINATION_ACQUIRE_TIMEOUT_SECONDS=120
FARESCOPE_COLLECTION_COORDINATION_POLL_INTERVAL_SECONDS=0.5
FARESCOPE_COLLECTION_COORDINATION_REDIS_TIMEOUT_SECONDS=2
FARESCOPE_COLLECTION_COORDINATION_KEY_PREFIX=farescope:collection-coordination
FARESCOPE_COLLECTION_PROVIDER_CONCURRENCY=1
FARESCOPE_COLLECTION_ROUTE_CONCURRENCY=1
FARESCOPE_COLLECTION_MINIMUM_INTERVAL_SECONDS=30
FARESCOPE_COLLECTION_JITTER_SECONDS=15
FARESCOPE_COLLECTION_CAPTURE_SETTLE_SECONDS=5
FARESCOPE_COLLECTION_SCHEDULER_TICK_SECONDS=30
FARESCOPE_COLLECTION_SCHEDULER_SUBSCRIPTION_BATCH_SIZE=500
FARESCOPE_COLLECTION_SCHEDULER_DISPATCH_BATCH_SIZE=100
FARESCOPE_COLLECTION_SCHEDULE_BUCKET_SECONDS=300
FARESCOPE_COLLECTION_PARTITION_MAINTENANCE_SECONDS=3600
FARESCOPE_COLLECTION_PARTITION_ARCHIVE_AFTER_MONTHS=24
# Permanent deletion is disabled unless this is explicitly set above the archive horizon.
# FARESCOPE_COLLECTION_PARTITION_PURGE_AFTER_MONTHS=84
FARESCOPE_COLLECTION_PARTITION_MAX_ACTIONS=2
FARESCOPE_COLLECTION_REALTIME_STREAM_KEY=farescope:realtime:collection-runs
FARESCOPE_COLLECTION_REALTIME_STREAM_MAX_LENGTH=20000
FARESCOPE_COLLECTION_REALTIME_SNAPSHOT_LIMIT=100
FARESCOPE_COLLECTION_REALTIME_READ_COUNT=100
FARESCOPE_COLLECTION_REALTIME_BLOCK_MS=15000
FARESCOPE_COLLECTION_REALTIME_CONNECTION_SECONDS=300
FARESCOPE_COLLECTION_REALTIME_REDIS_TIMEOUT_SECONDS=2
FARESCOPE_COLLECTION_REALTIME_RETRY_MS=2000
FARESCOPE_EXPORT_DIRECTORY=./data/exports
FARESCOPE_EXPORT_MAX_RANGE_DAYS=366
FARESCOPE_EXPORT_MAX_ROWS=250000
FARESCOPE_EXPORT_MAX_FILE_BYTES=134217728
FARESCOPE_EXPORT_PAGE_SIZE=2000
FARESCOPE_EXPORT_FILE_TTL_SECONDS=604800
FARESCOPE_EXPORT_LEASE_SECONDS=900
FARESCOPE_EXPORT_MAX_ATTEMPTS=3
FARESCOPE_EXPORT_RETRY_BASE_SECONDS=60
FARESCOPE_EXPORT_DISPATCH_BATCH_SIZE=20
FARESCOPE_EXPORT_DISPATCH_LEASE_SECONDS=300
FARESCOPE_EXPORT_PENDING_TIMEOUT_SECONDS=86400
FARESCOPE_EXPORT_MAX_ACTIVE_JOBS=5
FARESCOPE_EXPORT_GLOBAL_MAX_ACTIVE_JOBS=100
FARESCOPE_EXPORT_MANIFEST_MAX_RUNS=20000
FARESCOPE_EXPORT_USER_MAX_RETAINED_FILES=20
FARESCOPE_EXPORT_USER_MAX_RETAINED_BYTES=1073741824
FARESCOPE_EXPORT_MIN_FREE_BYTES=2147483648
FARESCOPE_EXPORT_MIN_FREE_RATIO=0.1
FARESCOPE_EXPORT_ORPHAN_GRACE_SECONDS=86400
FARESCOPE_EXPORT_ORPHAN_CLEANUP_BATCH_SIZE=100

POSTGRES_DB=farescope
POSTGRES_USER=farescope
POSTGRES_PASSWORD=farescope
